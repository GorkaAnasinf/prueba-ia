# ============================================================
# Copiar como .env y ajustar valores antes de levantar Docker
# ============================================================

# Proyecto
COMPOSE_PROJECT_NAME=ai-platform

# LiteLLM — clave maestra para autenticar peticiones al proxy
LITELLM_MASTER_KEY=sk-change-me-litellm-master-key

# Open WebUI — clave secreta para sesiones
WEBUI_SECRET_KEY=change-me-webui-secret-32-chars-min

# PostgreSQL
POSTGRES_USER=aiplatform
POSTGRES_PASSWORD=change-me-postgres-password
POSTGRES_DB=aiplatform

# Redis
REDIS_PASSWORD=change-me-redis-password

# Backend FastAPI — clave para autenticar peticiones a la API propia
API_KEY=sk-change-me-api-key
